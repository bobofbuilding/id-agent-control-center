{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ID Agents Control Center",
  "version": "0.1.0",
  "identifier": "world.idchain.idagents-control",
  "build": {
    "frontendDist": "../dist-tauri",
    "beforeBuildCommand": "node scripts/build-tauri.mjs",
    "beforeDevCommand": "node scripts/build-tauri.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "ID Agents Control Center",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "icon": ["icons/icon.icns", "icons/icon.png"]
  }
}
