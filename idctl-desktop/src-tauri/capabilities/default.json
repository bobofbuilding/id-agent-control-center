{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Manager + inference-backend HTTP access",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:*/*" },
        { "url": "http://localhost:*/*" },
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://api.openai.com/*" }
      ]
    }
  ]
}
